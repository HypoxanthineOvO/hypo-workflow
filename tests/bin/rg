#!/bin/bash
set -euo pipefail

fixed=0
quiet=0
args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -q)
      quiet=1
      shift
      ;;
    -F)
      fixed=1
      shift
      ;;
    -Fq|-qF)
      fixed=1
      quiet=1
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      args+=("$1")
      shift
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -lt 1 ]]; then
  exit 2
fi

pattern="$1"
shift

grep_args=()
if [[ "$quiet" -eq 1 ]]; then
  grep_args+=("-q")
fi
if [[ "$fixed" -eq 1 ]]; then
  grep_args+=("-F")
else
  grep_args+=("-E")
fi

if [[ $# -eq 0 ]]; then
  grep "${grep_args[@]}" -- "$pattern"
else
  grep "${grep_args[@]}" -- "$pattern" "$@"
fi
